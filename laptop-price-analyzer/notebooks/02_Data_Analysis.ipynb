import math

CORE_MAP = {
    'Dual-Core': 2,
    'Quad-Core': 4,
    'Hexa-Core': 6,
    'Octa-Core': 8,
    'Deca-Core': 10,
}
MONTH_MAP = {m:i for i,m in enumerate(['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'], start=1)}

def extract_first_int(text, default=np.nan):
    if pd.isna(text):
        return default
    m = re.search(r"(\d+)", str(text))
    return int(m.group(1)) if m else default

def parse_storage(storage_str):
    ssd_gb = 0
    hdd_gb = 0
    if pd.isna(storage_str):
        return ssd_gb, hdd_gb
    text = str(storage_str)
    # SSD
    for qty, unit in re.findall(r"(\d+)\s*(TB|GB)\s*SSD", text, flags=re.I):
        val = int(qty) * (1024 if unit.upper()=="TB" else 1)
        ssd_gb += val
    # HDD
    for qty, unit in re.findall(r"(\d+)\s*(TB|GB)\s*HDD", text, flags=re.I):
        val = int(qty) * (1024 if unit.upper()=="TB" else 1)
        hdd_gb += val
    return ssd_gb, hdd_gb

def parse_ram(storage_str):
    if pd.isna(storage_str):
        return np.nan
    m = re.search(r"(\d+)\s*GB\s*.*?RAM", str(storage_str), flags=re.I)
    return int(m.group(1)) if m else np.nan

def parse_display_inches(display_str):
    if pd.isna(display_str):
        return np.nan
    m = re.search(r"(\d+(?:\.\d+)?)\"", str(display_str))
    return float(m.group(1)) if m else np.nan

def parse_resolution(display_str):
    if pd.isna(display_str):
        return np.nan, np.nan
    m = re.search(r"(\d{3,4})\s*x\s*(\d{3,4})", str(display_str))
    return (int(m.group(1)), int(m.group(2))) if m else (np.nan, np.nan)

def parse_cpu_brand(processor_str):
    if pd.isna(processor_str):
        return 'Unknown'
    s = str(processor_str)
    if s.lower().startswith('intel'):
        return 'Intel'
    if s.lower().startswith('amd'):
        return 'AMD'
    if s.lower().startswith('apple'):
        return 'Apple'
    return s.split()[0]

def parse_cpu_series(processor_str):
    if pd.isna(processor_str):
        return 'Unknown'
    s = str(processor_str)
    m = re.search(r"(Ryzen\s*\d|Core\s*[iI]\d|M\d)", s)
    return m.group(1) if m else 'Other'

def parse_clock_ghz(processor_str):
    if pd.isna(processor_str):
        return np.nan
    m = re.search(r"(\d+(?:\.\d+)?)\s*Ghz", str(processor_str), flags=re.I)
    return float(m.group(1)) if m else np.nan

def parse_core_count(processor_str):
    if pd.isna(processor_str):
        return np.nan
    for key, val in CORE_MAP.items():
        if key.lower() in str(processor_str).lower():
            return val
    return np.nan

def parse_os_family(os_str):
    if pd.isna(os_str):
        return 'Unknown'
    s = str(os_str)
    if 'Windows' in s:
        return 'Windows'
    if 'macOS' in s or 'Mac' in s:
        return 'macOS'
    if 'Linux' in s:
        return 'Linux'
    if 'DOS' in s or 'No OS' in s:
        return 'No OS'
    return s.split()[0]

def flag_present(x):
    return 1 if pd.notna(x) and str(x).strip() != '' else 0

work = df.copy()
work['ram_gb'] = work['storage'].apply(parse_ram)
work[['ssd_gb','hdd_gb']] = work['storage'].apply(lambda s: pd.Series(parse_storage(s)))
work['screen_inches'] = work['display'].apply(parse_display_inches)
work[['res_width','res_height']] = work['display'].apply(lambda s: pd.Series(parse_resolution(s)))
work['cpu_brand'] = work['processor'].apply(parse_cpu_brand)
work['cpu_series'] = work['processor'].apply(parse_cpu_series)
work['max_clock_ghz'] = work['processor'].apply(parse_clock_ghz)
work['core_count'] = work['processor'].apply(parse_core_count)
work['os_family'] = work['windows'].apply(parse_os_family)
for col in ['Wifi','bluetooth','camera','slim','hdmi']:
    work[f'has_{col.lower()}'] = work[col].apply(flag_present)
work['usb_ports'] = work['usb'].apply(lambda x: extract_first_int(x, default=0))
work['released_year'] = work['released'].apply(lambda s: int(str(s).split()[-1]) if pd.notna(s) and str(s).split()[-1].isdigit() else np.nan)
MONTH_MAP_FULL = MONTH_MAP
work['released_month'] = work['released'].apply(lambda s: MONTH_MAP_FULL.get(str(s).split()[0], np.nan) if pd.notna(s) else np.nan)
for col in ['price','no_rates','rating_100','spec_score']:
    if col in work:
        work[col] = pd.to_numeric(work[col], errors='coerce')

cols_to_drop = ['name','name_c','img','system_name','processor','windows','storage','display','Wifi','bluetooth','camera','slim','hdmi','usb','released']
work_model = work.drop(columns=[c for c in cols_to_drop if c in work.columns])

out_csv = OUTPUT_DIR/"processed_laptops.csv"
work_model.to_csv(out_csv, index=False)
print("Saved:", out_csv)import pandas as pd
